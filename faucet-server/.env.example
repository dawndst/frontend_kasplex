# Required
RPC_URL=            # Kasplex L2 testnet JSON-RPC endpoint
FAUCET_PRIVATE_KEY= # funded testnet key, 0x-prefixed

# Optional (defaults shown)
CHAIN_ID=           # if set, warns on mismatch at boot
PORT=8790
DRIP_KAS=50
COOLDOWN_HOURS=24
BALANCE_CAP_KAS=2
HOURLY_BUDGET=100
STATE_FILE=./faucet-state.json
ALLOW_ORIGIN=*
